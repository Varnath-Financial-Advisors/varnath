# Supabase configuration (frontend-safe values).
# Copy this file to ".env" for local dev, and set the same
# variables in your host (Vercel/Netlify) dashboard for production.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-ANON-PUBLISHABLE-KEY
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-ID
